S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=arcnem-vision
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=auto
INNGEST_APP_ID=arcnem-vision-api
INNGEST_DEV=1
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
