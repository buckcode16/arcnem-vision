PORT=3000
BETTER_AUTH_BASE_URL=http://host.docker.internal:3000
BETTER_AUTH_SECRET=secret
API_DEBUG=true
AUTH_ENABLE_SIGN_UP=true
AUTH_ENABLE_ORGANIZATION_CREATION=true
CLIENT_ORIGIN=arcnem-vision://app
DASHBOARD_ORIGIN=http://localhost:3001
TRUSTED_ORIGINS=
REDIS_URL=redis://host.docker.internal:6381
